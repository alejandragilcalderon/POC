{
  "name": "apod-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/verify-env.mjs --mode=development && next dev",
    "dev:mobile": "node scripts/verify-env.mjs --mode=development && next dev --hostname 0.0.0.0 --port 3000",
    "build": "node scripts/verify-env.mjs --mode=production && next build",
    "start": "node scripts/verify-env.mjs --mode=production && next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
