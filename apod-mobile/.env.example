# Copy to .env
# - iOS Simulator / web: http://127.0.0.1:3000/api is fine
# - Android emulator: 127.0.0.1 / localhost are auto-rewritten to 10.0.2.2 (host machine)
# - Physical phone (any OS): use your computer's LAN IP, e.g. http://192.168.1.10:3000/api
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3000/api
